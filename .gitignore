# Virtualenv
venv/
.venv/
.venv-*/
.env

# macOS
.DS_Store

# Audio artifacts (run locally, never committed)
*.mp3
*.m4a
*.wav
*.part

# Whisper outputs and model cache
transcripts/
.cache/

# Podcast library — large/binary artifacts only; everything else (jsonl,
# md, vocab) is checked in so the library state is reproducible from git.
podcast-library/audio/
podcast-library/transcripts/**/*.mp3
podcast-library/transcripts/**/*.m4a
podcast-library/transcripts/**/*.wav

# Python build/packaging
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Claude/Cowork session artifacts
.claude/
