# Virtualenv
venv/
.venv/
.venv-*/
.env

# macOS
.DS_Store

# Audio artifacts (run locally, never committed)
*.mp3
*.m4a
*.wav
*.part

# Top-level Whisper outputs from the base CLI (the library has its own
# transcripts/ tree under podcast-library/ — see below — which IS tracked).
/transcripts/
.cache/

# Podcast library — personal archive of third-party episode content kept
# local-only. The transcripts, AI summaries, and JSONL/index are NOT
# tracked: they reproduce other publishers' material and don't belong in a
# public repo. The tooling under src/ regenerates this tree from scratch.
podcast-library/audio/
podcast-library/transcripts/
podcast-library/summaries/
podcast-library/index/

# Python build/packaging
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Claude/Cowork session artifacts
.claude/
