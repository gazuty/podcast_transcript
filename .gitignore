# Virtualenv
venv/
.venv/
.venv-*/
.env

# macOS
.DS_Store

# Audio artifacts (run locally, never committed)
*.mp3
*.m4a
*.wav
*.part

# Top-level Whisper outputs from the base CLI (the library has its own
# transcripts/ tree under podcast-library/ — see below — which IS tracked).
/transcripts/
.cache/

# Podcast library — large/binary artifacts and regeneratable Whisper
# sidecars; the canonical .txt + _clean.txt stay in git so the library
# state is reproducible from the JSONL + summaries.
podcast-library/audio/
podcast-library/transcripts/**/*.mp3
podcast-library/transcripts/**/*.m4a
podcast-library/transcripts/**/*.wav
podcast-library/transcripts/**/*.srt
podcast-library/transcripts/**/*.vtt
podcast-library/transcripts/**/*.tsv
podcast-library/transcripts/**/*.json

# Python build/packaging
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Claude/Cowork session artifacts
.claude/
